# ==========================================
# Agent Internet — Environment Configuration
# ==========================================

# --- Registry / API Gateway ---
REGISTRY_HOST=0.0.0.0
REGISTRY_PORT=8000
# Docker 环境使用: sqlite+aiosqlite:////app/data/registry.db
# 本地开发使用: sqlite+aiosqlite:///data/registry.db
REGISTRY_DATABASE_URL=sqlite+aiosqlite:///data/registry.db
REGISTRY_LOG_LEVEL=INFO

# --- Embedding ---
# Optional HuggingFace mirror, for example https://hf-mirror.com
HF_ENDPOINT=
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Discovery Engine ---
DISCOVERY_EPSILON=0.15           # ε-贪心探索率
DISCOVERY_NEWCOMER_BOOST=0.10    # 新秀助推权重
DISCOVERY_NEWCOMER_DAYS=30       # 新秀助推天数
DISCOVERY_DIVERSITY_PENALTY=0.05 # 同 provider 去重惩罚

# --- Session Manager ---
SESSION_MAX_TURNS=50             # 单会话最大轮次
SESSION_DEADLOCK_THRESHOLD=5     # 连续 disagree 触发僵局的阈值
SESSION_TIMEOUT_SECONDS=600      # 会话超时（秒）
SESSION_MAX_NESTING_DEPTH=3      # 最大嵌套深度

# --- Billing ---
BILLING_PLATFORM_FEE_RATE=0.15   # 平台抽成比例
BILLING_PAYOUT_THRESHOLD=50.0    # Agent 最低结算金额 (USD)
FREE_TRIAL_QUOTA=100             # 新 Agent 免费试用次数
FREE_TRIAL_EXTENSION=50          # 评分 2.5-3.9 的额外免费次数
USER_SIGNUP_CREDIT=5.00          # 新用户注册赠金 (USD)

# --- Auth ---
# Required for any non-local deployment. Never use the example value in production.
# AGENT_API_KEY_PREFIX=ait_
# USER_JWT_SECRET=change-me-in-production
# USER_JWT_ALGORITHM=HS256
# USER_JWT_EXPIRE_MINUTES=1440

# --- Stripe (optional; billing workflow is MVP/reference only) ---
# STRIPE_SECRET_KEY=<stripe-secret-key>
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CONNECT_CLIENT_ID=ca_...

# --- Demo Agent ports ---
AGENT_PORT_CREDIT_RISK=9121
AGENT_PORT_SUPPLY_CHAIN=9122
AGENT_PORT_ECHO=9123

# --- Dashboard ---
DASHBOARD_PORT=8501
# Docker 环境使用: http://backend:8000
# 本地开发使用: http://localhost:8000
DASHBOARD_REGISTRY_URL=http://localhost:8000

# --- Docker Agent Runtime ---
# Agent 名称: credit-risk-analyst, supply-chain-expert, echo
# AGENT_NAME=echo
# AGENT_PORT=9123
# REGISTRY_URL=http://backend:8000

# --- External LLM API (optional, for LLM-powered agents) ---
# LLM_API_KEY=<provider-api-key>
